{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/cron/order-timeout?key=change-admin-key",
      "schedule": "0 0 * * *"
    }
  ]
}
